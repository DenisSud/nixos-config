{
  "outline_panel": {
    "dock": "right"
  },
  "assistant": {
    "default_model": {
      "provider": "openai",
      "model": "deepseek-r1-distill-llama-70b"
    },
    "version": "2"
  },
  "features": {
    "inline_completion_provider": "supermaven"
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Base16 Classic Light",
    "dark": "Base16 Classic Dark"
  },
  "relative_line_numbers": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true
  },
  "language_models": {
    "google": {
      "available_models": [
        {
          "name": "gemini-2.0-flash-thinking-exp-1219",
          "display_name": "Gemini 2.0 Thinking",
          "max_tokens": 32000
        },
        {
          "name": "gemini-2.0-flash-exp",
          "display_name": "Gemini 2.0 Flash",
          "max_tokens": 1000000
        }
      ]
    },
    "openai": {
      "version": "1",
      "api_url": "https://api.groq.com/openai/v1",
      "low_speed_timeout_in_seconds": 60,
      "available_models": [
        {
          "name": "llama-3.3-70b-versatile",
          "max_tokens": 8000
        },
        {
          "name": "deepseek-r1-distill-llama-70b",
          "max_tokens": 128000
        }
      ]
    }
  },
  "languages": {
    "Python": {
      "format_on_save": { "language_server": { "name": "ruff" } },
      "formatter": { "language_server": { "name": "ruff" } },
      "language_servers": ["pyright", "ruff"],
      "tab_size": 4,
      "soft_tabs": true
    },
    "Lua": {
      "tab_size": 4,
      "soft_tabs": true,
      "format_on_save": {
        "external": {
          "command": "stylua",
          "arguments": ["-"]
        }
      }
    },
    "JavaScript": {
      "tab_size": 2,
      "soft_tabs": true,
      "format_on_save": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{filepath}"]
        }
      }
    },
    "TypeScript": {
      "tab_size": 2,
      "soft_tabs": true,
      "format_on_save": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{filepath}"]
        }
      }
    },
    "Rust": {
      "tab_size": 4,
      "soft_tabs": true,
      "format_on_save": {
        "external": {
          "command": "rustfmt"
        }
      }
    }
  },
  "tab_size": 2
}
