{
  "features": {
    "inline_completion_provider": "supermaven"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true
  },
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "Base16 Classic Light",
    "dark": "Base16 Mountain"
  },
  "relative_line_numbers": true,
  "terminal": {
    "font_size": 14,
    "working_directory": "current_project_directory",
    "shell": "system",
    "copy_on_select": true
  },
  "status_bar": {
    "show": true
  },
  "project_panel": {
    "dock": "left",
    "git_status": true
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "tab_size": 2,
  "search": {
    "case_sensitive": false,
    "whole_word": false,
    "use_regex": false
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "git": {
    "git_gutter": "tracked_files"
  }
}
